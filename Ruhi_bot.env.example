# Ruhi_bot Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# REQUIRED CONFIGURATION
# ===========================================

# Telegram API Credentials (Get from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot Token (Get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# MongoDB Database URI (Your MongoDB connection string)
MONGO_DB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourAppName

# Owner ID (Your Telegram user ID)
OWNER_ID=your_telegram_user_id

# Logger Channel ID (Create a channel and add bot as admin)
LOGGER_ID=-100xxxxxxxxxxxxx

# String Session (Pyrogram session string for userbot)
STRING_SESSION=your_string_session_here

# ===========================================
# OPTIONAL API KEYS (For additional features)
# ===========================================

# DeepAI API Key (for AI features)
DEEP_API=your_deepai_api_key_here

# GPT API Key (for ChatGPT integration)
GPT_API=your_gpt_api_key_here

# OpenAI API Key (alternative AI option)
OPENAI_API_KEY=your_openai_api_key_here

# Joke API URL (for joke commands)
JOKE_API_URL=https://api.example.com/jokes

# Stripe API Key (for payment features)
STRIPE_API_KEY=your_stripe_api_key_here

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# NexGenBots API (if using NexGen services)
NEXGENBOTS_API=https://pvtz.nexgenbots.xyz

# Video API URL (for video download features)
VIDEO_API_URL=https://pvtz.nexgenbots.xyz

# Custom API Key (for custom integrations)
API_KEY=your_custom_api_key_here

# ===========================================
# NOTES:
# ===========================================
# 1. Never share your .env file with anyone
# 2. Keep your API keys and tokens secure
# 3. Get API_ID and API_HASH from https://my.telegram.org
# 4. Get BOT_TOKEN from @BotFather on Telegram
# 5. Generate STRING_SESSION using the generate_session.py script
# 6. MONGO_DB_URI should be your MongoDB Atlas connection string
# 7. LOGGER_ID should be a channel/supergroup ID where bot logs will be sent
